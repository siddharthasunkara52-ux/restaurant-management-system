<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | RestaurantOS</title>
  <meta name="description" content="Sign in to RestaurantOS">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="auth-container">
    <div class="auth-card slide-up">
      <div class="auth-logo">
        <div class="auth-logo-icon" aria-hidden="true">🍽️</div>
        <h1>RestaurantOS</h1>
        <p>Sign in to your restaurant dashboard</p>
      </div>

      <% if (error) { %>
        <div class="auth-error" role="alert"><%= error %></div>
      <% } %>

      <form method="POST" action="/auth/login">
        <div class="form-group">
          <label class="form-label" for="email">Email</label>
          <input type="email" id="email" name="email" class="form-input" placeholder="you@restaurant.com" required autofocus autocomplete="email">
        </div>
        <div class="form-group">
          <label class="form-label" for="password">Password</label>
          <input type="password" id="password" name="password" class="form-input" placeholder="••••••••" required autocomplete="current-password">
        </div>
        <button type="submit" class="btn btn-primary btn-lg mt-2 w-full rounded-xl shadow-lg shadow-indigo-500/25">Sign in</button>
      </form>

      <div class="auth-footer">
        New here? <a href="/auth/register">Create an account</a>
      </div>
    </div>
  </div>
</body>
</html>
