<!DOCTYPE html>
<html lang="en">
<%- include('../partials/header.ejs', { title: title || 'Menu' }) %>
<body class="bg-[#F3F4F6] font-inter text-gray-900 antialiased">
  <div class="app-layout">
    <%- include('../partials/mobile-nav.ejs') %>
    <%- include('../partials/sidebar.ejs', { active: 'menu' }) %>

    <main class="main-content">
      <div class="page-header !mb-10 flex-wrap items-center gap-4 rounded-2xl border border-gray-200 bg-white p-6 shadow-surface lg:p-8">
        <div>
          <p class="text-xs font-bold uppercase tracking-wider text-primary-600">Catalog</p>
          <h1 class="page-title mt-1">Menu</h1>
          <p class="page-subtitle"><%= menuItems.length %> items · toggle availability anytime</p>
        </div>
        <button type="button" class="btn btn-primary min-h-[48px] rounded-xl px-5 shadow-lg shadow-indigo-500/25 transition hover:-translate-y-0.5" onclick="document.getElementById('addModal').classList.add('active')">
          <i data-lucide="plus" class="h-4 w-4"></i>
          Add item
        </button>
      </div>

      <div class="card !rounded-2xl !border-gray-200 !p-0 !shadow-surface overflow-hidden">
        <% if (menuItems.length === 0) { %>
          <div class="empty-state py-20">
            <div class="empty-state-icon">🍽️</div>
            <h3>No menu items yet</h3>
            <p class="text-muted">Add dishes with photos to shine on the customer menu</p>
            <button type="button" class="btn btn-primary mt-4 min-h-[48px] rounded-xl" onclick="document.getElementById('addModal').classList.add('active')">Add first item</button>
          </div>
        <% } else { %>
          <div class="overflow-x-auto">
            <table class="data-table">
              <thead>
                <tr>
                  <th class="pl-8">Image</th>
                  <th>Name</th>
                  <th>Category</th>
                  <th>Price</th>
                  <th>Available</th>
                  <th class="pr-8">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% menuItems.forEach(item => { %>
                  <tr id="item-<%= item.id %>">
                    <td class="pl-8">
                      <% if (item.image) { %>
                        <img src="<%= item.image %>" alt="" class="image-preview">
                      <% } else { %>
                        <div class="image-preview flex items-center justify-center bg-gray-100 text-xl">🍽️</div>
                      <% } %>
                    </td>
                    <td>
                      <strong class="text-gray-900"><%= item.name %></strong>
                      <% if (item.description) { %>
                        <br><small class="text-muted"><%= item.description.substring(0, 60) %><%= item.description.length > 60 ? '…' : '' %></small>
                      <% } %>
                    </td>
                    <td><%= item.category_name || '—' %></td>
                    <td class="font-bold text-gray-900">₹<%= parseFloat(item.price).toFixed(2) %></td>
                    <td>
                      <label class="toggle">
                        <input type="checkbox" <%= item.is_available ? 'checked' : '' %> onchange="toggleItem('<%= item.id %>')">
                        <span class="toggle-slider"></span>
                      </label>
                    </td>
                    <td class="pr-8">
                      <div class="actions">
                        <button type="button" class="btn btn-ghost btn-sm min-h-[40px] rounded-lg" onclick="editItem('<%= item.id %>', '<%= item.name.replace(/'/g, "\\'") %>', '<%= (item.description || '').replace(/'/g, "\\'").replace(/\n/g, ' ') %>', '<%= item.price %>', '<%= item.category_id || '' %>')">Edit</button>
                        <button type="button" class="btn btn-danger btn-sm min-h-[40px] rounded-lg" onclick="deleteItem('<%= item.id %>')">Delete</button>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </main>
  </div>

  <div class="modal-overlay" id="addModal">
    <div class="modal !max-w-lg !rounded-2xl">
      <div class="modal-header">
        <h3 class="modal-title">Add menu item</h3>
        <button type="button" class="modal-close" onclick="document.getElementById('addModal').classList.remove('active')" aria-label="Close">&times;</button>
      </div>
      <form method="POST" action="/admin/menu" enctype="multipart/form-data">
        <div class="form-group">
          <label class="form-label">Name</label>
          <input type="text" name="name" class="form-input" placeholder="e.g. Butter chicken" required>
        </div>
        <div class="form-group">
          <label class="form-label">Description</label>
          <textarea name="description" class="form-textarea" placeholder="Short, appetizing description" rows="2"></textarea>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Price (₹)</label>
            <input type="number" name="price" class="form-input" step="0.01" min="0" required>
          </div>
          <div class="form-group">
            <label class="form-label">Category</label>
            <select name="category_id" class="form-select">
              <option value="">No category</option>
              <% categories.forEach(cat => { %>
                <option value="<%= cat.id %>"><%= cat.name %></option>
              <% }) %>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Photo</label>
          <input type="file" name="image" class="form-input py-2" accept="image/*">
        </div>
        <button type="submit" class="btn btn-primary btn-lg mt-2 w-full rounded-xl">Save item</button>
      </form>
    </div>
  </div>

  <div class="modal-overlay" id="editModal">
    <div class="modal !max-w-lg !rounded-2xl">
      <div class="modal-header">
        <h3 class="modal-title">Edit menu item</h3>
        <button type="button" class="modal-close" onclick="document.getElementById('editModal').classList.remove('active')" aria-label="Close">&times;</button>
      </div>
      <form method="POST" id="editForm" enctype="multipart/form-data">
        <div class="form-group">
          <label class="form-label">Name</label>
          <input type="text" name="name" id="editName" class="form-input" required>
        </div>
        <div class="form-group">
          <label class="form-label">Description</label>
          <textarea name="description" id="editDescription" class="form-textarea" rows="2"></textarea>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Price (₹)</label>
            <input type="number" name="price" id="editPrice" class="form-input" step="0.01" min="0" required>
          </div>
          <div class="form-group">
            <label class="form-label">Category</label>
            <select name="category_id" id="editCategory" class="form-select">
              <option value="">No category</option>
              <% categories.forEach(cat => { %>
                <option value="<%= cat.id %>"><%= cat.name %></option>
              <% }) %>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">New photo (optional)</label>
          <input type="file" name="image" class="form-input py-2" accept="image/*">
        </div>
        <button type="submit" class="btn btn-primary btn-lg mt-2 w-full rounded-xl">Update item</button>
      </form>
    </div>
  </div>

  <script>
    <% if (success) { %>
    document.addEventListener('DOMContentLoaded', function () {
      if (typeof showToast === 'function') showToast(<%- JSON.stringify(success) %>, 'success');
    });
    <% } %>
    <% if (error) { %>
    document.addEventListener('DOMContentLoaded', function () {
      if (typeof showToast === 'function') showToast(<%- JSON.stringify(error) %>, 'error');
    });
    <% } %>

    async function toggleItem(id) {
      try {
        await fetch('/admin/menu/' + id + '/toggle', { method: 'PATCH' });
        if (typeof showToast === 'function') showToast('Availability updated', 'success');
      } catch (err) {
        console.error(err);
        location.reload();
      }
    }

    async function deleteItem(id) {
      if (!confirm('Delete this item?')) return;
      try {
        const res = await fetch('/admin/menu/' + id, { method: 'DELETE' });
        const data = await res.json();
        if (data.success) {
          const row = document.getElementById('item-' + id);
          if (row) row.remove();
          if (typeof showToast === 'function') showToast('Item removed', 'success');
        }
      } catch (err) {
        console.error(err);
        location.reload();
      }
    }

    function editItem(id, name, description, price, categoryId) {
      document.getElementById('editForm').action = '/admin/menu/' + id + '/update';
      document.getElementById('editName').value = name;
      document.getElementById('editDescription').value = description;
      document.getElementById('editPrice').value = price;
      document.getElementById('editCategory').value = categoryId;
      document.getElementById('editModal').classList.add('active');
    }

    document.querySelectorAll('.modal-overlay').forEach(function (overlay) {
      overlay.addEventListener('click', function (e) {
        if (e.target === overlay) overlay.classList.remove('active');
      });
    });
  </script>
  <%- include('../partials/footer.ejs') %>
