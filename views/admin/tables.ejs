<!DOCTYPE html>
<html lang="en">
<%- include('../partials/header.ejs', { title: title || 'Tables' }) %>
<body class="bg-[#F3F4F6] font-inter text-gray-900 antialiased">
  <div class="app-layout">
    <%- include('../partials/mobile-nav.ejs') %>
    <%- include('../partials/sidebar.ejs', { active: 'tables' }) %>

    <main class="main-content">
      <div class="page-header !mb-10 flex-wrap items-center gap-4 rounded-2xl border border-gray-200 bg-white p-6 shadow-surface lg:p-8">
        <div>
          <p class="text-xs font-bold uppercase tracking-wider text-primary-600">Floor</p>
          <h1 class="page-title mt-1">Tables &amp; QR</h1>
          <p class="page-subtitle"><%= tables.length %> tables · scan to open the guest menu</p>
        </div>
        <button type="button" class="btn btn-primary min-h-[48px] rounded-xl px-5 shadow-lg shadow-indigo-500/25 transition hover:-translate-y-0.5" onclick="document.getElementById('addModal').classList.add('active')">
          <i data-lucide="plus" class="h-4 w-4"></i>
          Add table
        </button>
      </div>

      <div class="card !rounded-2xl !border-gray-200 !p-0 !shadow-surface overflow-hidden">
        <% if (tables.length === 0) { %>
          <div class="empty-state py-20">
            <div class="empty-state-icon">🪑</div>
            <h3>No tables yet</h3>
            <p class="text-muted">Each table gets a unique QR ordering link</p>
          </div>
        <% } else { %>
          <div class="overflow-x-auto">
            <table class="data-table">
              <thead>
                <tr>
                  <th class="pl-8">Table</th>
                  <th>Capacity</th>
                  <th>Active</th>
                  <th>QR</th>
                  <th>Link</th>
                  <th class="pr-8">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% tables.forEach(table => { %>
                  <tr id="table-<%= table.id %>">
                    <td class="pl-8"><strong>Table <%= table.table_number %></strong></td>
                    <td><%= table.capacity %> seats</td>
                    <td>
                      <label class="toggle">
                        <input type="checkbox" <%= table.is_active ? 'checked' : '' %> onchange="toggleTable('<%= table.id %>')">
                        <span class="toggle-slider"></span>
                      </label>
                    </td>
                    <td>
                      <button type="button" class="btn btn-ghost btn-sm min-h-[40px] rounded-lg" onclick="showQR('<%= table.id %>')">View QR</button>
                    </td>
                    <td class="max-w-[200px]">
                      <code class="break-all text-xs font-medium text-indigo-600"><%= baseUrl %>/r/<%= restaurant.id %>/table/<%= table.id %></code>
                    </td>
                    <td class="pr-8">
                      <div class="actions">
                        <a href="/qr/<%= table.id %>/download" class="btn btn-success btn-sm min-h-[40px] rounded-lg">Download</a>
                        <button type="button" class="btn btn-danger btn-sm min-h-[40px] rounded-lg" onclick="deleteTable('<%= table.id %>')">Delete</button>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </main>
  </div>

  <div class="modal-overlay" id="addModal">
    <div class="modal !max-w-md !rounded-2xl">
      <div class="modal-header">
        <h3 class="modal-title">Add table</h3>
        <button type="button" class="modal-close" onclick="document.getElementById('addModal').classList.remove('active')">&times;</button>
      </div>
      <form method="POST" action="/admin/tables">
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Table number</label>
            <input type="number" name="table_number" class="form-input" min="1" required>
          </div>
          <div class="form-group">
            <label class="form-label">Capacity</label>
            <input type="number" name="capacity" class="form-input" min="1" value="4">
          </div>
        </div>
        <button type="submit" class="btn btn-primary btn-lg w-full rounded-xl">Create table</button>
      </form>
    </div>
  </div>

  <div class="modal-overlay" id="qrModal">
    <div class="modal !max-w-sm text-center !rounded-2xl">
      <div class="modal-header relative justify-center border-0 pb-0">
        <h3 class="modal-title" id="qrModalTitle">QR code</h3>
        <button type="button" class="modal-close absolute right-0 top-0" onclick="document.getElementById('qrModal').classList.remove('active')" aria-label="Close">&times;</button>
      </div>
      <div id="qrModalContent" class="px-4 pb-2">
        <div class="spinner mx-auto my-10"></div>
      </div>
      <a id="qrDownloadLink" href="#" class="btn btn-success mb-6 mx-auto rounded-xl" style="display: none;">Download QR</a>
    </div>
  </div>

  <script>
    <% if (success) { %>
    document.addEventListener('DOMContentLoaded', function () {
      if (typeof showToast === 'function') showToast(<%- JSON.stringify(success) %>, 'success');
    });
    <% } %>
    <% if (error) { %>
    document.addEventListener('DOMContentLoaded', function () {
      if (typeof showToast === 'function') showToast(<%- JSON.stringify(error) %>, 'error');
    });
    <% } %>

    async function toggleTable(id) {
      try {
        await fetch('/admin/tables/' + id + '/toggle', { method: 'PATCH' });
        if (typeof showToast === 'function') showToast('Table updated', 'success');
      } catch (err) {
        console.error(err);
        location.reload();
      }
    }

    async function deleteTable(id) {
      if (!confirm('Delete this table?')) return;
      try {
        const res = await fetch('/admin/tables/' + id, { method: 'DELETE' });
        const data = await res.json();
        if (data.success) {
          document.getElementById('table-' + id).remove();
          if (typeof showToast === 'function') showToast('Table removed', 'success');
        }
      } catch (err) {
        console.error(err);
        location.reload();
      }
    }

    async function showQR(tableId) {
      const modal = document.getElementById('qrModal');
      const content = document.getElementById('qrModalContent');
      const downloadLink = document.getElementById('qrDownloadLink');
      content.innerHTML = '<div class="spinner mx-auto my-10"></div>';
      downloadLink.style.display = 'none';
      modal.classList.add('active');
      try {
        const res = await fetch('/qr/' + tableId);
        const data = await res.json();
        if (data.success) {
          document.getElementById('qrModalTitle').textContent = 'Table ' + data.tableNumber;
          content.innerHTML =
            '<div class="mx-auto mt-2 inline-block rounded-2xl border border-gray-100 bg-white p-4 shadow-sm">' +
            '<img src="' + data.qrCode + '" alt="QR" width="240" height="240" class="rounded-lg"></div>' +
            '<p class="mt-4 break-all px-2 text-xs text-gray-500">' + data.url + '</p>';
          downloadLink.href = '/qr/' + tableId + '/download';
          downloadLink.style.display = 'inline-flex';
        }
      } catch (err) {
        content.innerHTML = '<p class="text-danger py-8 text-sm">Could not load QR</p>';
      }
    }

    document.querySelectorAll('.modal-overlay').forEach(function (overlay) {
      overlay.addEventListener('click', function (e) {
        if (e.target === overlay) overlay.classList.remove('active');
      });
    });
  </script>
  <%- include('../partials/footer.ejs') %>
