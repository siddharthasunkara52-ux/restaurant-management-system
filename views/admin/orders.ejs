<!DOCTYPE html>
<html lang="en">
<%- include('../partials/header.ejs', { title: title || 'Orders' }) %>
<body class="bg-[#F3F4F6] font-inter text-gray-900 antialiased">
  <div class="app-layout">
    <%- include('../partials/mobile-nav.ejs') %>
    <%- include('../partials/sidebar.ejs', { active: 'orders' }) %>

    <main class="main-content">
      <div class="mb-8 flex flex-col gap-4 rounded-2xl border border-gray-200 bg-white p-6 shadow-surface sm:flex-row sm:items-end sm:justify-between lg:p-8">
        <div>
          <p class="text-xs font-bold uppercase tracking-wider text-primary-600">Operations</p>
          <h1 class="page-title mt-1">Orders</h1>
          <p class="page-subtitle">Filter, update status, and mark payments</p>
        </div>
      </div>

      <div class="mb-6 flex flex-wrap gap-2">
        <% const filters = [
          ['all', 'All'],
          ['pending', 'Pending'],
          ['confirmed', 'Confirmed'],
          ['preparing', 'Preparing'],
          ['ready', 'Ready'],
          ['served', 'Served'],
          ['cancelled', 'Cancelled'],
        ];
        filters.forEach(([val, label]) => { %>
          <a href="/admin/orders<%= val === 'all' ? '' : ('?status=' + val) %>"
             class="inline-flex min-h-[40px] items-center rounded-full border px-4 text-sm font-semibold shadow-sm transition <%= currentStatus === val ? 'border-indigo-300 bg-indigo-50 text-indigo-700 shadow-md' : 'border-gray-200 bg-white text-gray-600 hover:-translate-y-0.5 hover:border-indigo-200 hover:shadow-md hover:text-indigo-600' %>">
            <%= label %>
          </a>
        <% }); %>
      </div>

      <div class="overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-premium">
        <% if (orders.length === 0) { %>
          <div class="empty-state py-20">
            <div class="empty-state-icon text-4xl opacity-90">📭</div>
            <h3>No orders found</h3>
            <p class="text-muted">Try another filter or check back soon</p>
          </div>
        <% } else { %>
          <div class="overflow-x-auto">
            <table class="w-full min-w-[900px] border-collapse text-left">
              <thead>
                <tr class="border-b border-gray-200 bg-gray-100/90">
                  <th class="whitespace-nowrap px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-400">Order</th>
                  <th class="whitespace-nowrap px-4 py-4 text-xs font-bold uppercase tracking-wider text-gray-400">Table / Guest</th>
                  <th class="px-4 py-4 text-xs font-bold uppercase tracking-wider text-gray-400">Items</th>
                  <th class="whitespace-nowrap px-4 py-4 text-xs font-bold uppercase tracking-wider text-gray-400">Total</th>
                  <th class="whitespace-nowrap px-4 py-4 text-xs font-bold uppercase tracking-wider text-gray-400">Status</th>
                  <th class="whitespace-nowrap px-4 py-4 text-xs font-bold uppercase tracking-wider text-gray-400">Payment</th>
                  <th class="whitespace-nowrap px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-400">Time</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-50">
                <% orders.forEach(order => { %>
                  <tr id="order-<%= order.id %>" class="transition hover:bg-gray-50/80">
                    <td class="px-6 py-4">
                      <span class="inline-flex rounded-lg bg-gray-100 px-2 py-1 font-mono text-xs font-semibold text-gray-600">#<%= order.id.substring(0, 8) %></span>
                    </td>
                    <td class="px-4 py-4">
                      <p class="font-bold text-gray-900">Table <%= order.table_number %></p>
                      <p class="text-xs text-gray-500"><%= order.customer_name || 'Guest' %></p>
                    </td>
                    <td class="max-w-[220px] px-4 py-4 text-sm text-gray-600">
                      <% if (order.items && order.items[0] && order.items[0].id) { %>
                        <% order.items.forEach(item => { %>
                          <div class="leading-relaxed"><%= item.quantity %>× <%= item.item_name %></div>
                        <% }) %>
                      <% } else { %>
                        <span class="text-muted">—</span>
                      <% } %>
                    </td>
                    <td class="whitespace-nowrap px-4 py-4 font-bold text-gray-900">₹<%= parseFloat(order.total_price).toFixed(2) %></td>
                    <td class="px-4 py-4">
                      <select class="form-select max-w-[140px] cursor-pointer rounded-xl border-gray-200 py-2 text-xs font-semibold"
                              onchange="updateOrderStatus('<%= order.id %>', this.value)"
                              id="status-<%= order.id %>">
                        <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>Pending</option>
                        <option value="confirmed" <%= order.status === 'confirmed' ? 'selected' : '' %>>Confirmed</option>
                        <option value="preparing" <%= order.status === 'preparing' ? 'selected' : '' %>>Preparing</option>
                        <option value="ready" <%= order.status === 'ready' ? 'selected' : '' %>>Ready</option>
                        <option value="served" <%= order.status === 'served' ? 'selected' : '' %>>Served</option>
                        <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                      </select>
                    </td>
                    <td class="px-4 py-4">
                      <span class="badge badge-<%= order.payment_status %>"><%= order.payment_status %></span>
                      <% if (order.payment_status === 'unpaid') { %>
                        <button type="button" class="btn btn-success btn-sm mt-2 min-h-[36px] w-full max-w-[100px] rounded-lg text-xs" onclick="markPaid('<%= order.id %>')">Mark paid</button>
                      <% } %>
                    </td>
                    <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-500">
                      <%= new Date(order.created_at).toLocaleString('en-IN', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }) %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </main>
  </div>

  <script>
    <% if (success) { %>
    document.addEventListener('DOMContentLoaded', function () {
      if (typeof showToast === 'function') showToast(<%- JSON.stringify(success) %>, 'success');
    });
    <% } %>

    async function updateOrderStatus(id, status) {
      try {
        await fetch('/admin/orders/' + id + '/status', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status }),
        });
        if (typeof showToast === 'function') showToast('Status updated', 'success');
      } catch (err) {
        console.error(err);
        location.reload();
      }
    }

    async function markPaid(orderId) {
      try {
        const res = await fetch('/payment/' + orderId + '/mark-paid', { method: 'PATCH' });
        const data = await res.json();
        if (data.success) location.reload();
      } catch (err) {
        console.error(err);
      }
    }
  </script>
  <%- include('../partials/footer.ejs') %>
