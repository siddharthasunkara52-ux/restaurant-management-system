<!DOCTYPE html>
<html lang="en">
<%- include('../partials/header.ejs', { title: 'Restaurant Settings' }) %>
<body class="bg-[#F3F4F6] font-inter text-gray-900 antialiased">
  <div class="app-layout">
    <%- include('../partials/mobile-nav.ejs') %>
    <%- include('../partials/sidebar.ejs', { active: 'settings' }) %>
    <main class="main-content">
      <div class="mb-8 flex flex-col gap-4 rounded-2xl border border-gray-200 bg-white p-6 shadow-surface md:flex-row md:items-center md:justify-between lg:p-8">
        <div>
          <p class="text-xs font-bold uppercase tracking-wider text-primary-600">Configuration</p>
          <h1 class="page-title mt-1">Settings</h1>
          <p class="mt-1 text-slate-500">Manage your restaurant details and branding</p>
        </div>
      </div>

      <% if (success) { %>
        <div class="mb-6 flex items-center gap-3 rounded-xl border border-emerald-100 bg-emerald-50 p-4 text-emerald-700 shadow-sm">
          <i data-lucide="check-circle" class="h-5 w-5"></i>
          <p class="text-sm font-semibold"><%= success %></p>
        </div>
      <% } %>

      <% if (error) { %>
        <div class="mb-6 flex items-center gap-3 rounded-xl border border-rose-100 bg-rose-50 p-4 text-rose-700 shadow-sm">
          <i data-lucide="alert-circle" class="h-5 w-5"></i>
          <p class="text-sm font-semibold"><%= error %></p>
        </div>
      <% } %>

      <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">
        <!-- Main Settings Form -->
        <div class="lg:col-span-2">
          <div class="rounded-2xl border border-gray-200 bg-white shadow-premium overflow-hidden">
            <div class="border-b border-gray-100 bg-gray-50/50 px-6 py-4">
              <h2 class="text-sm font-bold text-gray-900 flex items-center gap-2">
                <i data-lucide="info" class="w-4 h-4 text-primary-500"></i>
                General Information
              </h2>
            </div>
            <form action="/admin/settings" method="POST" enctype="multipart/form-data" class="p-6 sm:p-8 space-y-6">
              <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
                <div class="space-y-2">
                  <label for="name" class="text-sm font-bold text-gray-700">Restaurant Name</label>
                  <input type="text" id="name" name="name" value="<%= restaurant.name %>" required
                    class="w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 text-sm transition focus:border-primary-500 focus:bg-white focus:outline-none focus:ring-4 focus:ring-primary-500/10">
                </div>
                <div class="space-y-2">
                  <label for="email" class="text-sm font-bold text-gray-700">Email Address</label>
                  <input type="email" id="email" value="<%= restaurant.email %>" disabled
                    class="w-full rounded-xl border border-gray-200 bg-gray-100 px-4 py-3 text-sm text-gray-500 cursor-not-allowed">
                  <p class="text-[11px] text-gray-400 italic">Email cannot be changed</p>
                </div>
                <div class="space-y-2">
                  <label for="phone" class="text-sm font-bold text-gray-700">Phone Number</label>
                  <input type="text" id="phone" name="phone" value="<%= restaurant.phone %>"
                    class="w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 text-sm transition focus:border-primary-500 focus:bg-white focus:outline-none focus:ring-4 focus:ring-primary-500/10">
                </div>
                <div class="space-y-2 sm:col-span-2">
                  <label for="address" class="text-sm font-bold text-gray-700">Address</label>
                  <textarea id="address" name="address" rows="3"
                    class="w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 text-sm transition focus:border-primary-500 focus:bg-white focus:outline-none focus:ring-4 focus:ring-primary-500/10"><%= restaurant.address %></textarea>
                </div>
              </div>

              <div class="pt-4 border-t border-gray-100">
                <div class="flex items-center gap-4">
                  <div class="w-16 h-16 rounded-2xl border border-gray-200 bg-gray-50 flex items-center justify-center overflow-hidden shrink-0">
                    <% if (restaurant.logo) { %>
                      <img src="<%= restaurant.logo %>" alt="Logo" class="w-full h-full object-cover">
                    <% } else { %>
                      <i data-lucide="image" class="w-8 h-8 text-gray-300"></i>
                    <% } %>
                  </div>
                  <div class="flex-1 space-y-1">
                    <label for="logo" class="text-sm font-bold text-gray-700 block">Restaurant Logo</label>
                    <input type="file" id="logo" name="logo" accept="image/*"
                      class="block w-full text-xs text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-semibold file:bg-primary-50 file:text-primary-700 hover:file:bg-primary-100 transition">
                    <p class="text-[11px] text-gray-400">Recommended: Square image, max 5MB</p>
                  </div>
                </div>
              </div>

              <div class="pt-6 flex justify-end">
                <button type="submit" class="flex min-h-[44px] items-center gap-2 rounded-xl bg-primary-600 px-8 py-2 text-sm font-semibold text-white shadow-md shadow-primary-500/30 transition hover:-translate-y-0.5 hover:bg-primary-700 hover:shadow-lg">
                  <i data-lucide="save" class="h-4 w-4"></i>
                  Save Changes
                </button>
              </div>
            </form>
          </div>
        </div>

        <!-- Right Side Info -->
        <div class="space-y-8">
          <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-surface">
            <h3 class="text-sm font-bold text-gray-900 mb-4">Branding</h3>
            <div class="space-y-4">
              <div class="aspect-square w-full rounded-2xl bg-gray-50 border-2 border-dashed border-gray-200 flex flex-col items-center justify-center p-8 text-center">
                <% if (restaurant.logo) { %>
                  <img src="<%= restaurant.logo %>" alt="Logo Preview" class="w-32 h-32 object-contain mb-4 rounded-xl">
                  <p class="text-xs font-bold text-gray-900"><%= restaurant.name %></p>
                <% } else { %>
                  <div class="w-16 h-16 rounded-2xl bg-primary-100 text-primary-600 flex items-center justify-center mb-4">
                    <i data-lucide="utensils-crossed" class="w-8 h-8"></i>
                  </div>
                  <p class="text-xs font-bold text-gray-400">No logo uploaded</p>
                <% } %>
              </div>
              <p class="text-xs text-slate-500 leading-relaxed text-center">
                Your logo appears on the customer menu, order confirmation receipts, and your dashboard sidebar.
              </p>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
  <%- include('../partials/footer.ejs') %>
  <%- include('../partials/scripts.ejs') %>
</body>
</html>
