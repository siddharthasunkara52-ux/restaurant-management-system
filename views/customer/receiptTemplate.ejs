<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Receipt - <%= order.id.substring(0,8) %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
    body {
      font-family: 'Inter', sans-serif;
      background-color: transparent;
      margin: 0;
      padding: 0;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }
    .receipt-container {
      width: 100%;
      max-width: 800px;
      margin: 0 auto;
      padding: 40px;
      box-sizing: border-box;
      background: #ffffff;
    }
  </style>
</head>
<body>
  <div class="receipt-container">
    <div class="text-center mb-10">
      <h1 class="text-4xl font-extrabold text-gray-900 mb-2 truncate"><%= restaurant.name %></h1>
      <% if (restaurant.address) { %>
      <p class="text-sm text-gray-600 mb-1 w-2/3 mx-auto leading-tight"><%= restaurant.address %></p>
      <% } %>
      <p class="text-sm text-gray-500 font-medium tracking-wide"><%= restaurant.phone || 'Phone not available' %></p>
    </div>
    <hr class="border-t-2 border-gray-100 mb-8 w-1/2 mx-auto">
    <div class="flex justify-between items-end mb-8">
      <div>
        <h2 class="text-sm font-semibold tracking-widest text-indigo-500 uppercase mb-2">Tax Invoice</h2>
        <p class="text-2xl font-bold text-gray-900">Order #<%= order.id.substring(0, 8) %></p>
        <p class="text-sm text-gray-500 mt-1">Table <%= order.table_number %></p>
      </div>
      <div class="text-right">
        <p class="text-sm text-gray-900 font-semibold mb-1"><%= order.customer_name || 'Guest' %></p>
        <p class="text-sm text-gray-500"><%= new Date(order.created_at).toLocaleString('en-IN', {
          day: '2-digit', month: 'short', year: 'numeric',
          hour: '2-digit', minute: '2-digit'
        }) %></p>
      </div>
    </div>
    <div class="mb-10 p-6 bg-gray-50/50 rounded-3xl border border-gray-100">
      <h3 class="text-xl font-bold text-gray-900 mb-6">Order Details</h3>
      <table class="w-full text-left border-collapse mb-4">
        <thead>
          <tr class="border-b-2 border-gray-200 text-gray-500 text-xs uppercase tracking-wider">
            <th class="py-3 font-semibold w-5/12">Item</th>
            <th class="py-3 font-semibold text-center w-2/12">Qty</th>
            <th class="py-3 font-semibold text-right w-2/12">Price</th>
            <th class="py-3 font-semibold text-right w-3/12">Amount</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% order.items.forEach(function(item) { %>
          <tr>
            <td class="py-4 text-sm font-bold text-gray-900"><%= item.item_name %></td>
            <td class="py-4 text-sm text-center text-gray-600"><%= item.quantity %></td>
            <td class="py-4 text-sm text-right text-gray-600">₹<%= parseFloat(item.price).toFixed(2) %></td>
            <td class="py-4 text-sm font-bold text-right text-gray-900">₹<%= (item.quantity * item.price).toFixed(2) %></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
      <%
         const subtotal = parseFloat(order.total_price);
         const gstAmount = subtotal * 0.05;
         const grandTotal = subtotal + gstAmount;
      %>
      <div class="mt-6 pt-6 border-t font-mono border-dashed border-gray-300">
        <div class="flex justify-between items-center mb-3">
          <span class="text-sm font-semibold text-gray-500">Subtotal</span>
          <span class="text-sm font-bold text-gray-700">₹<%= subtotal.toFixed(2) %></span>
        </div>
        <div class="flex justify-between items-center mb-6">
          <span class="text-sm font-semibold text-gray-500">GST (5%)</span>
          <span class="text-sm font-bold text-gray-700">₹<%= gstAmount.toFixed(2) %></span>
        </div>
        <div class="flex justify-between items-center p-5 bg-indigo-50 rounded-2xl border border-indigo-100/50">
          <span class="text-base font-bold text-indigo-900 tracking-wider">TOTAL</span>
          <span class="text-3xl font-extrabold text-indigo-600">₹<%= grandTotal.toFixed(2) %></span>
        </div>
      </div>
    </div>
    <div class="flex justify-between items-center p-6 bg-white border border-gray-200 rounded-3xl mb-12 shadow-sm">
      <div>
        <h4 class="text-xs font-bold tracking-widest text-gray-400 uppercase mb-2">Payment Method</h4>
        <div class="text-sm font-bold text-gray-700">
          Razorpay
        </div>
        <div class="flex items-center gap-2 mt-2">
          <span class="text-xs font-bold tracking-widest text-gray-400 uppercase">Status:</span>
          <% if (order.payment_status === 'paid') { %>
            <div class="px-3 py-1 bg-emerald-100 text-emerald-700 rounded-full text-xs font-bold flex items-center gap-1.5">
              <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              PAID
            </div>
          <% } else { %>
            <div class="px-3 py-1 bg-amber-100 text-amber-700 rounded-full text-xs font-bold">
              UNPAID
            </div>
          <% } %>
        </div>
      </div>
      <% if (order.razorpay_payment_id) { %>
      <div class="text-right">
        <h4 class="text-xs font-bold tracking-widest text-gray-400 uppercase mb-1">Transaction Ref</h4>
        <span class="text-sm font-mono font-medium text-gray-600 bg-gray-50 px-2 py-1 rounded truncate relative max-w-[200px] block">
          <%= order.razorpay_payment_id %>
        </span>
      </div>
      <% } %>
    </div>
    <div class="text-center pt-8 border-t border-gray-100">
      <p class="text-lg font-medium italic text-gray-500">Thank you for visiting! 😊</p>
    </div>
  </div>
</body>
</html>
