<!DOCTYPE html>
<html lang="en">
<%- include('../partials/customer-head.ejs', { title: 'Order status' }) %>

  <body class="min-h-screen bg-[#F3F4F6] font-sans text-gray-900 antialiased">
    <div class="order-status-page !max-w-xl !bg-transparent">

      <!-- Success hero -->
      <div class="mb-8 rounded-2xl border border-gray-200 bg-white p-8 text-center shadow-surface slide-up sm:p-10">
        <h1 class="font-outfit text-2xl font-extrabold">Order confirmed</h1>
        <p class="mt-2 text-sm text-gray-500">Track progress below</p>
        <span>#<%= order.id.substring(0, 8) %></span>
      </div>

      <!-- Payment Section -->
      <div class="card !rounded-2xl !border-gray-200 !p-6 !shadow-surface">
        <div class="flex justify-between items-center">
          <div>
            <h2 class="font-outfit text-lg font-bold">Payment</h2>
            <span class="badge badge-<%= order.payment_status %>">
              <%= order.payment_status %>
            </span>
          </div>

          <% if (order.payment_status==='unpaid' ) { %>
            <!-- ✅ UPDATED BUTTON -->
            <button class="btn btn-primary px-6" onclick="handlePayment('<%= order.id %>')">
              Pay Now
            </button>
            <% } %>
        </div>
      </div>

    </div>

    <%- include('../partials/scripts.ejs') %>

      <!-- ✅ Razorpay Script -->
      <script src="https://checkout.razorpay.com/v1/checkout.js"></script>

      <!-- ✅ EXISTING POLL -->
      <script>
        const orderId = '<%= order.id %>';
        const pollStatus = async () => {
          try {
            const res = await fetch('/api/order/' + orderId + '/status');
            const data = await res.json();
            if (data.success && data.status !== '<%= order.status %>') {
              location.reload();
            }
          } catch (err) {
            console.error(err);
          }
        };
        setInterval(pollStatus, 15000);
      </script>

      <!-- ✅ NEW PAYMENT FUNCTION -->
      <script>
        async function handlePayment(orderId) {
          try {
            const res = await fetch("/api/create-order", {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
              },
              body: JSON.stringify({ orderId }),
            });

            const data = await res.json();

            const options = {
              key: data.order.razorpayKeyId,
              amount: data.order.amount,
              currency: data.order.currency,
              order_id: data.order.razorpayOrderId,
              name: "Restaurant App",

              handler: async function (response) {
                await fetch("/api/verify-payment", {
                  method: "POST",
                  headers: {
                    "Content-Type": "application/json",
                  },
                  body: JSON.stringify({
                    orderId,
                    razorpay_payment_id: response.razorpay_payment_id,
                    razorpay_order_id: response.razorpay_order_id,
                    razorpay_signature: response.razorpay_signature,
                  }),
                });

                alert("Payment Successful ✅");
                location.reload();
              },
            };

            const rzp = new Razorpay(options);
            rzp.open();

          } catch (err) {
            console.error(err);
            alert("Payment Failed ❌");
          }
        }
      </script>

  </body>

</html>