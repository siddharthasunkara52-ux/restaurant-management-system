<!DOCTYPE html>
<html lang="en">
<%- include('../partials/customer-head.ejs', { title: 'Order status' }) %>
<body class="min-h-screen bg-[#F3F4F6] font-sans text-gray-900 antialiased">
  <div class="order-status-page !max-w-xl !bg-transparent">
    <!-- Success hero -->
    <div class="mb-8 rounded-2xl border border-gray-200 bg-white p-8 text-center shadow-surface slide-up sm:p-10">
      <div class="mx-auto mb-5 flex h-20 w-20 items-center justify-center rounded-full bg-gradient-to-br from-emerald-400 to-emerald-600 shadow-lg shadow-emerald-500/35 ring-8 ring-gray-100">
        <svg class="h-10 w-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path>
        </svg>
      </div>
      <h1 class="font-outfit text-2xl font-extrabold tracking-tight text-gray-900 sm:text-3xl">Order confirmed</h1>
      <p class="mt-2 text-sm text-gray-500">We&rsquo;re on it — track progress below</p>
      <div class="mt-5 inline-flex flex-col gap-1 rounded-xl border border-gray-200 bg-gray-50 px-5 py-3 shadow-inner">
        <span class="text-xs font-semibold uppercase tracking-wider text-gray-400">Order ID</span>
        <span class="font-mono text-base font-bold text-primary-600">#<%= order.id.substring(0, 8) %></span>
      </div>
      <p class="mt-4 text-sm text-gray-600">
        <span class="font-semibold text-gray-900"><%= order.restaurant_name %></span>
        <span class="text-gray-300">·</span>
        Table <%= order.table_number %>
      </p>
    </div>

    <!-- Tracker -->
    <div class="card mb-5 !rounded-2xl !border-gray-200 !p-6 !shadow-surface">
      <h2 class="font-outfit mb-5 text-lg font-bold text-gray-900">Kitchen progress</h2>
      <div class="status-tracker" id="statusTracker">
        <% 
          const statuses = ['pending', 'confirmed', 'preparing', 'ready', 'served'];
          const cancelledOrders = order.status === 'cancelled';
          const currentIndex = statuses.indexOf(order.status);
        %>
        <% if (cancelledOrders) { %>
          <div class="status-step active">
            <div class="status-dot border-red-200 bg-red-50 text-red-600">✕</div>
            <div class="status-info">
              <h4 class="text-red-700">Order cancelled</h4>
              <p>This order is no longer active</p>
            </div>
          </div>
        <% } else { %>
          <% const icons = ['📝', '✓', '🍳', '🔔', '🍽️'];
          const labels = ['Received', 'Confirmed', 'Preparing', 'Ready', 'Served'];
          const descriptions = [
            'Sent to the restaurant',
            'Staff confirmed your order',
            'Kitchen is cooking your meal',
            'Ready for pickup at the table',
            'Enjoy your meal!'
          ];
          statuses.forEach((s, i) => { 
            const isCompleted = i < currentIndex;
            const isActive = i === currentIndex;
          %>
            <div class="status-step <%= isCompleted ? 'completed' : '' %> <%= isActive ? 'active' : '' %>">
              <div class="status-dot"><%= isCompleted ? '✓' : icons[i] %></div>
              <div class="status-info">
                <h4><%= labels[i] %></h4>
                <p><%= descriptions[i] %></p>
              </div>
            </div>
          <% }); %>
        <% } %>
      </div>
    </div>

    <!-- Line items -->
    <div class="card mb-5 !rounded-2xl !border-gray-200 !p-6 !shadow-surface">
      <h2 class="font-outfit mb-4 text-lg font-bold text-gray-900">Your order</h2>
      <% if (order.items && order.items[0] && order.items[0].id) { %>
        <% order.items.forEach(item => { %>
          <div class="flex items-center justify-between gap-3 border-b border-gray-50 py-3 last:border-0">
            <span class="text-sm font-medium text-gray-800"><span class="font-bold text-gray-900"><%= item.quantity %>×</span> <%= item.item_name %></span>
            <span class="shrink-0 text-sm font-bold text-gray-900">₹<%= (parseFloat(item.price) * item.quantity).toFixed(0) %></span>
          </div>
        <% }) %>
      <% } %>
      <div class="mt-4 flex items-center justify-between rounded-xl bg-gradient-to-r from-gray-50 to-indigo-50/50 px-4 py-3">
        <span class="text-sm font-bold text-gray-600">Total</span>
        <span class="text-lg font-extrabold text-primary-600">₹<%= parseFloat(order.total_price).toFixed(0) %></span>
      </div>
    </div>

    <!-- Payment -->
    <div class="card !rounded-2xl !border-gray-200 !p-6 !shadow-surface">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h2 class="font-outfit text-lg font-bold text-gray-900">Payment</h2>
          <span class="badge badge-<%= order.payment_status %> mt-2"><%= order.payment_status %></span>
        </div>
        <% if (order.payment_status === 'unpaid') { %>
          <button type="button" class="btn btn-primary min-h-[48px] rounded-xl px-6" onclick="typeof showToast === 'function' ? showToast('Connect Razorpay in .env to enable payments.', 'info') : alert('Configure payment keys in .env')">
            Pay now
          </button>
        <% } %>
      </div>
    </div>

    <p class="mt-8 text-center text-xs text-gray-400" id="lastUpdated">Updates every 15 seconds</p>
  </div>

  <%- include('../partials/scripts.ejs') %>
  <script>
    const orderId = '<%= order.id %>';
    const pollStatus = async () => {
      try {
        const res = await fetch('/api/order/' + orderId + '/status');
        const data = await res.json();
        if (data.success && data.status !== '<%= order.status %>') {
          location.reload();
        }
        const el = document.getElementById('lastUpdated');
        if (el) {
          el.textContent = 'Last checked ' + new Date().toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
        }
      } catch (err) {
        console.error(err);
      }
    };
    setInterval(pollStatus, 15000);
  </script>
</body>
</html>
