<!DOCTYPE html>
<html lang="en">
<%- include('../partials/customer-head.ejs', { title: 'Order Status' }) %>
  <body class="min-h-screen bg-[#F3F4F6] font-sans text-gray-900 antialiased">
    <div class="order-status-page !max-w-xl !bg-transparent">
      <div class="mb-6 rounded-2xl border border-gray-200 bg-white p-6 text-center shadow-surface slide-up sm:p-8">
        <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-emerald-400 to-emerald-600 shadow-lg shadow-emerald-500/30">
          <svg class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
        </div>
        <h1 class="font-outfit text-2xl font-extrabold text-gray-900">Order Placed!</h1>
        <p class="mt-1.5 text-sm text-gray-500">Your order has been sent to the kitchen</p>
        <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-gray-200 bg-gray-50 px-4 py-1.5 text-sm font-bold text-gray-600">
          <span class="text-gray-400">ID</span>
          <span class="font-mono">#<%= order.id.substring(0, 8) %></span>
        </div>
        <% if (order.restaurant_name) { %>
        <p class="mt-3 text-sm font-semibold text-gray-700"><%= order.restaurant_name %></p>
        <% } %>
        <p class="mt-1 text-xs text-gray-400">Table <%= order.table_number %></p>
      </div>
      <div class="mb-6 rounded-2xl border border-gray-200 bg-white p-6 shadow-surface slide-up sm:p-8">
        <h2 class="font-outfit text-lg font-bold text-gray-900 mb-5">Order Status</h2>
        <%
          const statusSteps = [
            { key: 'pending',   label: 'Order Placed',  desc: 'Waiting for kitchen to confirm', icon: '📋' },
            { key: 'confirmed', label: 'Confirmed',     desc: 'Kitchen has accepted your order', icon: '✅' },
            { key: 'preparing', label: 'Preparing',     desc: 'Your food is being prepared', icon: '👨‍🍳' },
            { key: 'ready',     label: 'Ready',         desc: 'Your order is ready to serve', icon: '🔔' },
            { key: 'served',    label: 'Served',        desc: 'Enjoy your meal!', icon: '🍽️' },
          ];
          const statusOrder = ['pending', 'confirmed', 'preparing', 'ready', 'served'];
          const currentIdx = statusOrder.indexOf(order.status);
          const isCancelled = order.status === 'cancelled';
        %>
        <% if (isCancelled) { %>
          <div class="rounded-xl bg-red-50 border border-red-200 p-4 text-center">
            <p class="text-lg font-bold text-red-600">Order Cancelled</p>
            <p class="mt-1 text-sm text-red-500">This order has been cancelled</p>
          </div>
        <% } else { %>
          <div class="status-tracker" id="statusTracker">
            <% statusSteps.forEach(function(step, idx) { %>
              <%
                let stepClass = '';
                if (idx < currentIdx) stepClass = 'completed';
                else if (idx === currentIdx) stepClass = 'active';
              %>
              <div class="status-step <%= stepClass %>">
                <div class="status-dot">
                  <% if (idx < currentIdx) { %>
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  <% } else if (idx === currentIdx) { %>
                    <span class="text-sm"><%= step.icon %></span>
                  <% } else { %>
                    <span class="text-xs text-gray-400"><%= idx + 1 %></span>
                  <% } %>
                </div>
                <div class="status-info">
                  <h4 class="<%= idx <= currentIdx ? 'text-gray-900' : 'text-gray-400' %>"><%= step.label %></h4>
                  <p class="<%= idx <= currentIdx ? 'text-gray-500' : 'text-gray-300' %>"><%= step.desc %></p>
                </div>
              </div>
            <% }); %>
          </div>
        <% } %>
      </div>
      <% if (order.items && order.items.length > 0) { %>
      <div class="mb-6 rounded-2xl border border-gray-200 bg-white p-6 shadow-surface slide-up sm:p-8">
        <h2 class="font-outfit text-lg font-bold text-gray-900 mb-4">Order Summary</h2>
        <div class="space-y-3">
          <% order.items.forEach(function(item) { %>
            <div class="flex items-center justify-between gap-3 rounded-xl border border-gray-100 bg-gray-50 px-4 py-3">
              <div class="min-w-0">
                <p class="font-semibold text-gray-900 truncate"><%= item.item_name %></p>
                <p class="text-xs text-gray-500"><%= item.quantity %> × ₹<%= parseFloat(item.price).toFixed(0) %></p>
                <% if (item.special_instructions) { %>
                  <p class="mt-1 text-xs text-amber-600 font-medium">📝 <%= item.special_instructions %></p>
                <% } %>
              </div>
              <p class="font-bold text-gray-900 whitespace-nowrap">₹<%= (parseFloat(item.price) * item.quantity).toFixed(0) %></p>
            </div>
          <% }); %>
        </div>
        <%
           var subtotal = parseFloat(order.total_price);
           var gstAmount = subtotal * 0.05;
           var grandTotal = subtotal + gstAmount;
        %>
        <div class="mt-4 border-t border-gray-100 pt-3 space-y-2">
          <div class="flex items-center justify-between px-4">
            <span class="text-xs font-semibold text-gray-500">Subtotal</span>
            <span class="text-sm font-bold text-gray-700">₹<%= subtotal.toFixed(0) %></span>
          </div>
          <div class="flex items-center justify-between px-4">
            <span class="text-xs font-semibold text-gray-500">GST (5%)</span>
            <span class="text-sm font-bold text-gray-700">₹<%= gstAmount.toFixed(0) %></span>
          </div>
          <div class="mt-2 flex items-center justify-between rounded-xl border border-indigo-100 bg-indigo-50/50 px-4 py-3">
            <span class="text-xs font-bold uppercase tracking-wider text-gray-400">Total</span>
            <span class="font-outfit text-xl font-extrabold text-[#4F46E5]">₹<%= grandTotal.toFixed(0) %></span>
          </div>
        </div>
      </div>
      <% } else {
         var subtotal = 0;
         var grandTotal = 0;
      } %>
      <div class="mb-6 rounded-2xl border border-gray-200 bg-white p-6 shadow-surface slide-up sm:p-8">
        <div class="flex items-center justify-between gap-4">
          <div>
            <h2 class="font-outfit text-lg font-bold text-gray-900">Payment</h2>
            <span class="badge badge-<%= order.payment_status %> mt-1" id="paymentBadge">
              <%= order.payment_status %>
            </span>
          </div>
          <div class="flex flex-col gap-2 relative">
            <% if (order.payment_status === 'unpaid') { %>
              <button class="btn btn-primary px-6 rounded-xl shadow-lg shadow-indigo-500/25" id="payNowBtn" onclick="handlePayment('<%= order.id %>')">
                Pay ₹<%= grandTotal.toFixed(0) %>
              </button>
            <% } else if (order.payment_status === 'paid') { %>
              <div class="flex items-center gap-2 text-emerald-600 justify-end">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                <span class="font-bold text-sm">Paid</span>
              </div>
            <% } %>
            <button class="btn btn-outline px-6 rounded-xl text-sm border-gray-300 text-gray-700 hover:bg-gray-50 flex items-center gap-2" id="downloadReceiptBtn" onclick="downloadReceipt('<%= order.id %>')">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
              Receipt
            </button>
          </div>
        </div>
      </div>
      <div class="mb-8 text-center text-xs text-gray-400">
        Ordered at <%= new Date(order.created_at).toLocaleString('en-IN', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
      </div>
      <div class="mb-6 flex items-center justify-center gap-2 text-xs text-gray-400">
        <span class="inline-block h-2 w-2 rounded-full bg-emerald-400" style="animation: pulse-dot 2s ease-in-out infinite;"></span>
        Live updates every 10 seconds
      </div>
    </div>
    <%- include('../partials/scripts.ejs') %>
      <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
      <script>
        const orderId = '<%= order.id %>';
        let currentStatus = '<%= order.status %>';
        let currentPayment = '<%= order.payment_status %>';
        const pollStatus = async () => {
          try {
            const res = await fetch('/api/order/' + orderId + '/status');
            const data = await res.json();
            if (data.success) {
              if (data.status !== currentStatus || data.payment_status !== currentPayment) {
                location.reload();
              }
            }
          } catch (err) {
            console.error('Poll error:', err);
          }
        };
        setInterval(pollStatus, 10000);
      </script>
      <script>
        async function handlePayment(orderId) {
          var btn = document.getElementById('payNowBtn');
          if (btn) { btn.disabled = true; btn.textContent = 'Processing…'; }
          try {
            const res = await fetch("/payment/create", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ orderId }),
            });
            const data = await res.json();
            if (!data.success) {
              alert(data.error || 'Could not create payment');
              if (btn) { btn.disabled = false; btn.textContent = 'Pay Now'; }
              return;
            }
            const options = {
              key: data.order.razorpayKeyId,
              amount: data.order.amount,
              currency: data.order.currency,
              order_id: data.order.razorpayOrderId,
              name: "RestaurantOS",
              description: "Order #" + orderId.substring(0, 8),
              handler: async function (response) {
                try {
                  await fetch("/payment/verify", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                      orderId,
                      razorpay_payment_id: response.razorpay_payment_id,
                      razorpay_order_id: response.razorpay_order_id,
                      razorpay_signature: response.razorpay_signature,
                    }),
                  });
                  location.reload();
                } catch (e) {
                  console.error(e);
                  alert("Payment verification failed. Please contact staff.");
                  location.reload();
                }
              },
              modal: {
                ondismiss: function () {
                  if (btn) { btn.disabled = false; btn.textContent = 'Pay Now'; }
                }
              },
            };
            const rzp = new Razorpay(options);
            rzp.open();
          } catch (err) {
            console.error(err);
            alert("Payment Failed. Please try again.");
            if (btn) { btn.disabled = false; btn.textContent = 'Pay Now'; }
          }
        }
        async function downloadReceipt(orderId) {
          const btn = document.getElementById('downloadReceiptBtn');
          const originalText = btn.innerHTML;
          btn.disabled = true;
          btn.innerHTML = '<span class="inline-block h-4 w-4 rounded-full border-2 border-gray-300 border-t-gray-600 animate-spin mr-2"></span> Loading...';
          try {
            const res = await fetch('/api/receipt/' + orderId);
            if (!res.ok) throw new Error('Network response was not ok');
            const blob = await res.blob();
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.style.display = 'none';
            a.href = url;
            a.download = `receipt-${orderId.substring(0, 8)}.pdf`;
            document.body.appendChild(a);
            a.click();
            window.URL.revokeObjectURL(url);
          } catch (error) {
            console.error('Error downloading receipt:', error);
            alert('Failed to download receipt');
          } finally {
            btn.innerHTML = originalText;
            btn.disabled = false;
          }
        }
      </script>
  </body>
</html>