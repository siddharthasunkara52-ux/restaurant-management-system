<!DOCTYPE html>
<html lang="en">
<%- include('../partials/customer-head.ejs', { title: title }) %>

  <body class="min-h-screen bg-[#F3F4F6] font-sans text-gray-900 antialiased">

    <%# Inject ALL menu data as a safe JSON blob — zero JS string escaping issues %>
      <script type="application/json" id="MENU_DATA"><%- JSON.stringify({
    restaurantId: restaurantId,
    tableId: tableId,
    items: Object.values(menuByCategory).flat().map(function(item) {
      return { id: item.id, name: item.name, price: parseFloat(item.price) };
    })
  }) %></script>

      <div class="customer-page !max-w-2xl !pb-32">

        <!-- Hero card -->
        <div class="mb-5 rounded-2xl border border-gray-200 bg-white p-6 shadow-surface sm:p-7">
          <header class="customer-header !p-0 text-center">
            <div
              class="mx-auto mb-4 flex h-16 w-16 items-center justify-center overflow-hidden rounded-2xl bg-gradient-to-br from-[#4F46E5] to-indigo-600 shadow-lg shadow-indigo-500/30 ring-4 ring-gray-100">
              <% if (restaurantData.logo) { %>
                <img src="<%= restaurantData.logo %>" alt="" class="h-full w-full object-cover">
                <% } else { %>
                  <span class="text-3xl" aria-hidden="true">🍽️</span>
                  <% } %>
            </div>
            <h1 class="font-outfit text-2xl font-extrabold tracking-tight text-gray-900 sm:text-3xl">
              <%= restaurantData.name %>
            </h1>
            <p class="mt-1.5 text-sm text-gray-500">Order from your table in a few taps</p>
            <div class="table-badge mt-5 inline-flex border border-indigo-200/80 shadow-sm">Table <%= table.table_number
                %>
            </div>
          </header>
        </div>

        <!-- Category tabs -->
        <div class="mb-8 rounded-2xl border border-gray-200 bg-white p-3 shadow-surface">
          <p class="mb-2 px-1 text-xs font-bold uppercase tracking-wider text-gray-400">Browse</p>
          <div class="category-tabs !mb-0 !pb-0">
            <button type="button" class="category-tab active shrink-0" data-cat="all"
              onclick="filterCategory('all', this)">All</button>
            <% Object.keys(menuByCategory).forEach(function(cat) { %>
              <button type="button" class="category-tab shrink-0" data-cat="<%= cat %>"
                onclick="filterCategory(this.dataset.cat, this)">
                <%= cat %>
              </button>
              <% }) %>
          </div>
        </div>

        <!-- Menu sections -->
        <div id="menuContainer" class="space-y-10">
          <% Object.entries(menuByCategory).forEach(function([categoryName, items]) { %>
            <section class="menu-section slide-up" data-category="<%= categoryName %>">
              <h2 class="menu-category-title">
                <%= categoryName %>
              </h2>
              <div class="menu-grid">
                <% items.forEach(function(item) { %>
                  <article class="menu-card group" id="menu-card-<%= item.id %>">
                    <% if (item.image) { %>
                      <img src="<%= item.image %>" alt="<%= item.name %>" class="menu-card-img" loading="lazy">
                      <% } else { %>
                        <div
                          class="menu-card-img flex items-center justify-center bg-gradient-to-br from-indigo-50 to-violet-50 text-3xl"
                          aria-hidden="true">🍽️</div>
                        <% } %>
                          <div class="menu-card-info pl-0 sm:pl-1">
                            <h3 class="menu-card-name text-gray-900 transition-colors group-hover:text-[#4F46E5]">
                              <%= item.name %>
                            </h3>
                            <% if (item.description) { %>
                              <p class="menu-card-desc">
                                <%= item.description %>
                              </p>
                              <% } %>
                                <div class="menu-card-footer">
                                  <span class="menu-card-price">₹<%= parseFloat(item.price).toFixed(0) %></span>

                                  <!-- ADD button visible by default -->
                                  <button type="button" class="add-btn" id="add-btn-<%= item.id %>"
                                    onclick="addItem('<%= item.id %>')">+ Add</button>

                                  <!-- QTY stepper hidden until item added -->
                                  <div class="qty-control" id="qty-control-<%= item.id %>" style="display:none"
                                    role="group">
                                    <button type="button" class="qty-btn"
                                      onclick="changeQty('<%= item.id %>', -1)">−</button>
                                    <span class="qty-value" id="qty-<%= item.id %>">0</span>
                                    <button type="button" class="qty-btn"
                                      onclick="changeQty('<%= item.id %>', 1)">+</button>
                                  </div>

                                </div>
                          </div>
                  </article>
                  <% }) %>
              </div>
            </section>
            <% }) %>
        </div>

        <!-- Checkout sheet -->
        <div class="modal-overlay checkout-sheet-overlay" id="checkoutModal" role="dialog" aria-modal="true"
          aria-labelledby="checkoutTitle">
          <div
            class="modal checkout-sheet-modal max-h-[92vh] w-full max-w-lg overflow-hidden rounded-2xl border border-gray-200 bg-white p-0">
            <div class="border-b border-gray-200 bg-white px-6 py-5">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <p class="text-xs font-bold uppercase tracking-wider text-[#4F46E5]">Your cart</p>
                  <h3 id="checkoutTitle" class="font-outfit mt-1 text-xl font-bold text-gray-900">Checkout</h3>
                  <p class="mt-1 text-sm text-gray-500">Review before sending to the kitchen</p>
                </div>
                <button type="button" class="modal-close shrink-0"
                  onclick="document.getElementById('checkoutModal').classList.remove('active')"
                  aria-label="Close">×</button>
              </div>
            </div>
            <div class="max-h-[min(52vh,420px)] overflow-y-auto bg-[#F3F4F6] px-4 py-4" id="orderSummary"></div>
            <div class="space-y-4 border-t border-gray-200 bg-white px-6 py-5">
              <div class="form-group mb-0">
                <label class="form-label" for="customerName">Your name <span
                    class="font-normal text-gray-400">(optional)</span></label>
                <input type="text" id="customerName" class="form-input" placeholder="e.g. Alex" autocomplete="name">
              </div>
              <div class="form-group mb-0">
                <label class="form-label" for="orderNotes">Special notes <span
                    class="font-normal text-gray-400">(optional)</span></label>
                <textarea id="orderNotes" class="form-textarea" rows="2"
                  placeholder="Allergies, spice level, etc."></textarea>
              </div>
              <button type="button" id="placeOrderBtn" onclick="placeOrder()" class="btn btn-primary btn-lg w-full"
                style="background:linear-gradient(180deg,#6366f1,#4F46E5);box-shadow:0 4px 14px rgba(79,70,229,0.45);">
                Place order
              </button>
            </div>
          </div>
        </div>

        <!-- Sticky cart bar -->
        <div class="cart-bar" id="cartBar" style="display:none">
          <div class="cart-info min-w-0">
            <span class="cart-count" id="cartCount">0 items</span>
            <span class="cart-total" id="cartTotal">₹0</span>
          </div>
          <button type="button" class="btn btn-primary min-h-[48px] rounded-xl px-6" onclick="showCheckout()">
            View cart &amp; order
          </button>
        </div>

      </div>

      <%- include('../partials/scripts.ejs') %>

        <style>
          .add-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 40px;
            min-width: 76px;
            padding: 0 14px;
            border-radius: 10px;
            border: 2px solid #4F46E5;
            background: #fff;
            color: #4F46E5;
            font-size: 0.875rem;
            font-weight: 700;
            cursor: pointer;
            transition: background 0.15s, color 0.15s;
            white-space: nowrap;
            -webkit-tap-highlight-color: transparent;
            touch-action: manipulation;
          }

          .add-btn:hover {
            background: #4F46E5;
            color: #fff;
          }

          .add-btn:active {
            opacity: 0.8;
          }

          .checkout-sheet-overlay {
            align-items: flex-end;
            padding: 0;
            background: rgba(15, 23, 42, 0.5);
          }

          @media (min-width:640px) {
            .checkout-sheet-overlay {
              align-items: center;
              padding: 1rem;
            }
          }

          .checkout-sheet-overlay .modal {
            transform: translateY(100%);
          }

          .checkout-sheet-overlay.active .modal {
            transform: translateY(0);
          }

          @media (min-width:640px) {
            .checkout-sheet-overlay .modal {
              transform: translateY(16px) scale(0.98);
            }

            .checkout-sheet-overlay.active .modal {
              transform: translateY(0) scale(1);
            }
          }
        </style>

        <script>
          // Read data from the safe JSON blob — no EJS string interpolation in JS
          var _d = JSON.parse(document.getElementById('MENU_DATA').textContent);
          var RID = _d.restaurantId;
          var TID = _d.tableId;
          var menuItems = {};
          _d.items.forEach(function (i) { menuItems[i.id] = i; });
          var cart = {};

          function addItem(id) {
            cart[id] = 1;
            document.getElementById('qty-' + id).textContent = 1;
            document.getElementById('add-btn-' + id).style.display = 'none';
            document.getElementById('qty-control-' + id).style.display = 'inline-flex';
            var c = document.getElementById('menu-card-' + id);
            if (c) c.classList.add('menu-card--active');
            updateCartBar();
          }

          function changeQty(id, delta) {
            cart[id] = Math.max(0, (cart[id] || 0) + delta);
            document.getElementById('qty-' + id).textContent = cart[id];
            if (cart[id] === 0) {
              document.getElementById('qty-control-' + id).style.display = 'none';
              document.getElementById('add-btn-' + id).style.display = 'inline-flex';
              var c = document.getElementById('menu-card-' + id);
              if (c) c.classList.remove('menu-card--active');
            }
            updateCartBar();
          }

          function updateCartBar() {
            var n = 0, total = 0;
            Object.keys(cart).forEach(function (id) {
              if (cart[id] > 0 && menuItems[id]) { n += cart[id]; total += cart[id] * menuItems[id].price; }
            });
            document.getElementById('cartCount').textContent = n + ' item' + (n !== 1 ? 's' : '');
            document.getElementById('cartTotal').textContent = '₹' + total.toFixed(0);
            document.getElementById('cartBar').style.display = n > 0 ? 'flex' : 'none';
          }

          function showCheckout() {
            var rows = '', total = 0;
            Object.keys(cart).forEach(function (id) {
              if (cart[id] > 0 && menuItems[id]) {
                var item = menuItems[id], sub = cart[id] * item.price;
                total += sub;
                rows += '<div style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px;background:#fff;border:1px solid #e5e7eb;border-radius:12px;padding:12px 16px;margin-bottom:10px;">'
                  + '<div><p style="font-weight:600;color:#111827;">' + esc(item.name) + '</p>'
                  + '<p style="font-size:.8125rem;color:#6b7280;">' + cart[id] + ' × ₹' + item.price.toFixed(0) + '</p></div>'
                  + '<p style="font-weight:700;color:#111827;">₹' + sub.toFixed(0) + '</p></div>';
              }
            });
            if (!rows) rows = '<p style="text-align:center;color:#9ca3af;padding:24px 0;">Your cart is empty.</p>';
            rows += '<div style="display:flex;justify-content:space-between;background:#fff;border:1px solid #e5e7eb;border-radius:12px;padding:14px 20px;margin-top:8px;">'
              + '<span style="font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#9ca3af;">Total</span>'
              + '<span style="font-size:1.25rem;font-weight:800;color:#4F46E5;">₹' + total.toFixed(0) + '</span></div>';
            document.getElementById('orderSummary').innerHTML = rows;
            document.getElementById('checkoutModal').classList.add('active');
          }

          function esc(s) { var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

          async function placeOrder() {
            var items = [];
            Object.keys(cart).forEach(function (id) {
              if (cart[id] > 0) items.push({ menu_item_id: id, quantity: cart[id], name: menuItems[id].name });
            });
            if (!items.length) { alert('Please add at least one item first.'); return; }
            var btn = document.getElementById('placeOrderBtn');
            btn.disabled = true; btn.textContent = 'Placing order…';
            try {
              var res = await fetch('/r/' + RID + '/table/' + TID + '/order', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  customer_name: (document.getElementById('customerName').value || '').trim() || 'Guest',
                  notes: (document.getElementById('orderNotes').value || '').trim(),
                  items: items
                })
              });
              var data = await res.json();
              if (data.success) { window.location.href = data.redirectUrl; }
              else { alert(data.error || 'Could not place order.'); btn.disabled = false; btn.textContent = 'Place order'; }
            } catch (e) {
              console.error(e);
              alert('Network error. Please try again.');
              btn.disabled = false; btn.textContent = 'Place order';
            }
          }

          function filterCategory(cat, btn) {
            document.querySelectorAll('.category-tab').forEach(function (t) { t.classList.remove('active'); });
            btn.classList.add('active');
            document.querySelectorAll('.menu-section').forEach(function (s) {
              s.style.display = (cat === 'all' || s.dataset.category === cat) ? '' : 'none';
            });
          }

          document.getElementById('checkoutModal').addEventListener('click', function (e) {
            if (e.target === this) this.classList.remove('active');
          });
        </script>
  </body>

</html>