<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | RestaurantOS</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@500;600&family=Outfit:wght@700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="error-page slide-up">
    <div>
      <p class="error-code"><%= statusCode %></p>
      <h2 class="mt-4 text-xl font-semibold text-gray-700"><%= message %></h2>
      <a href="/" class="btn btn-primary btn-lg mt-8 inline-flex min-w-[160px] rounded-xl">Back home</a>
    </div>
  </div>
</body>
</html>
