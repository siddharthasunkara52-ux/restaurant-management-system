<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title><%= typeof title !== 'undefined' ? title : 'Menu' %> · RestaurantOS</title>
  <meta name="theme-color" content="#4F46E5">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@600;700;800&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: { 50: '#eef2ff', 100: '#e0e7ff', 500: '#6366f1', 600: '#4f46e5', 700: '#4338ca' },
          },
          borderRadius: { '2xl': '16px', '3xl': '24px' },
          fontFamily: { sans: ['Inter', 'system-ui', 'sans-serif'], outfit: ['Outfit', 'sans-serif'] },
        },
      },
    };
  </script>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .font-outfit { font-family: 'Outfit', system-ui, sans-serif; }
    .shadow-surface {
      box-shadow: 0 1px 2px rgba(15, 23, 42, 0.05), 0 6px 16px -4px rgba(15, 23, 42, 0.1);
    }
    .shadow-premium {
      box-shadow: 0 1px 3px rgba(15, 23, 42, 0.06), 0 12px 32px -8px rgba(15, 23, 42, 0.12);
    }
  </style>
</head>
